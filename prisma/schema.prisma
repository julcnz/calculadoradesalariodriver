// Esquema de datos — ver reglas de negocio en CLAUDE.md.
// Regla 1: WorkLogEntry guarda snapshots (nameSnapshot/amountSnapshot); editar RateType jamás toca registros pasados.
// Regla 2: millas y horas son nullable; null significa "no registrado", nunca usar 0 por defecto.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String?
  weekStartDay    Int       @default(1) // 0=domingo … 6=sábado; todos los cálculos semanales lo respetan
  mileageRate     Decimal   @default(0.70) @db.Decimal(4, 2) // $/milla para la deducción estimada (tarifa IRS)
  vehicleMpg         Decimal? @db.Decimal(4, 1) // millas por galón del vehículo; null = sin configurar (regla 2)
  fuelPricePerGallon Decimal? @db.Decimal(5, 2) // $/galón; null = sin configurar
  monthlyFixedCosts  Decimal? @db.Decimal(10, 2) // gastos fijos $/mes para el punto de equilibrio; null = sin configurar
  incomeTaxRate      Decimal  @default(10) @db.Decimal(4, 1) // % efectivo de impuesto sobre ingreso para la estimación de /impuestos (el SE tax se calcula aparte)
  reminderEnabled    Boolean  @default(false) // recordatorio push diario para registrar el día
  reminderTime       String? // "HH:mm" en la hora local del usuario
  timeZone           String? // IANA persistida (espejo de la cookie tz; la usa el cron)
  reminderLastSentOn DateTime? @db.Date // último día local notificado (dedupe idempotente)
  avatar          Bytes? // foto de perfil reescalada a 256px en el cliente
  avatarMimeType  String?
  avatarUpdatedAt DateTime?
  suspendedAt     DateTime? // cuenta pausada; se reactiva al iniciar sesión (se borra a los 90 días)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  companies          Company[]
  suggestions        CompanySuggestion[]
  workLogs           WorkLog[]
  expenses           Expense[]
  goals              Goal[]
  resetTokens        PasswordResetToken[]
  verificationTokens EmailVerificationToken[]
  sessions           UserSession[]
  pushSubscriptions  PushSubscription[]
  sharedWeeks        SharedWeek[]
}

// Enlace público de resumen semanal (/s/[token]). Solo guardamos el hash
// del token (patrón EmailVerificationToken); el token en claro solo existe
// en la URL que se comparte. Un enlace activo por semana; revocable.
model SharedWeek {
  id        String    @id @default(cuid())
  userId    String
  weekStart DateTime  @db.Date
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Suscripción Web Push de un navegador/dispositivo (VAPID).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Sesión iniciada en un dispositivo. El JWT lleva el id; el layout de (app)
// verifica que no esté revocada y actualiza lastActiveAt (con throttle).
model UserSession {
  id           String    @id @default(cuid())
  userId       String
  userAgent    String?
  ip           String?
  createdAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Token de un solo uso para verificar el email (24 h).
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Token de un solo uso para restablecer contraseña. Se guarda el hash
// sha256 del token (nunca el token en claro) y expira en 1 hora.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id        String    @id @default(cuid())
  userId    String
  name      String
  isCustom  Boolean   @default(false) // escrita en "Otra: ___"
  isActive  Boolean   @default(true) // una activa por usuario; las demás quedan como historial
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  routes Route[]

  @@index([userId])
}

// Texto libre tal cual lo escribió el usuario, sin normalizar,
// para análisis posterior del administrador.
model CompanySuggestion {
  id        String   @id @default(cuid())
  userId    String
  rawText   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Route {
  id        String   @id @default(cuid())
  companyId String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rateTypes RateType[]
  workLogs  WorkLog[]

  @@index([companyId])
}

model RateType {
  id        String   @id @default(cuid())
  routeId   String
  name      String // "Tarifa completa", "Tarifa doble", …
  amount    Decimal  @db.Decimal(10, 2) // valor vigente; los registros usan snapshot
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  route   Route          @relation(fields: [routeId], references: [id], onDelete: Cascade)
  entries WorkLogEntry[]

  @@index([routeId])
}

model WorkLog {
  id            String   @id @default(cuid())
  userId        String
  routeId       String
  date          DateTime @db.Date
  startTime     String? // "HH:mm" hora local
  endTime       String? // "HH:mm"; puede ser menor que startTime (turno cruza medianoche)
  workedMinutes Int? // duración calculada; null = horas no registradas
  miles         Decimal? @db.Decimal(7, 1) // null = no registrado
  odometerStart Decimal? @db.Decimal(9, 1) // alternativa: millas = fin − inicio
  odometerEnd   Decimal? @db.Decimal(9, 1)
  note          String?
  totalEarned   Decimal  @db.Decimal(10, 2) // suma de subtotales; se recalcula al editar
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  route   Route          @relation(fields: [routeId], references: [id])
  entries WorkLogEntry[]

  @@index([userId, date])
}

model WorkLogEntry {
  id             String  @id @default(cuid())
  workLogId      String
  rateTypeId     String? // referencia informativa; SetNull si la tarifa se borra
  nameSnapshot   String
  amountSnapshot Decimal @db.Decimal(10, 2)
  quantity       Int
  subtotal       Decimal @db.Decimal(10, 2) // quantity × amountSnapshot

  workLog  WorkLog   @relation(fields: [workLogId], references: [id], onDelete: Cascade)
  rateType RateType? @relation(fields: [rateTypeId], references: [id], onDelete: SetNull)

  @@index([workLogId])
}

// ----- Fases futuras (solo esquema, sin UI en Fase 1) -----

model ExpenseCategory {
  id       String  @id @default(cuid())
  userId   String? // null = categoría predeterminada global
  name     String
  isCustom Boolean @default(false)

  expenses Expense[]
}

model Expense {
  id               String   @id @default(cuid())
  userId           String
  categoryId       String?
  originalFreeText String? // texto libre tal cual, sin normalizar
  amount           Decimal  @db.Decimal(10, 2)
  date             DateTime @db.Date
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
}

model Goal {
  id        String     @id @default(cuid())
  userId    String
  period    GoalPeriod
  amount    Decimal    @db.Decimal(10, 2)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}
